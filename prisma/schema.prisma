generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  gifts     Gift[]
  expenses  Expense[]
  replacements    Replacement[]
  openedRegisters CashRegister[] @relation("OpenedBy")
  closedRegisters CashRegister[] @relation("ClosedBy")
  cashMovements   CashMovement[]
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String   @default("📦")
  color     String   @default("#f59e0b")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id                String   @id @default(uuid())
  categoryId        String
  name              String
  brand             String   @default("")
  model             String   @default("")
  subCategory       String   @default("")
  purchasePrice     Float    @default(0)
  sellingPrice      Float    @default(0)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  isAlertDismissed  Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  category          Category @relation(fields: [categoryId], references: [id])
  sales             Sale[]
  gifts             Gift[]
  replacements      Replacement[]

  @@index([categoryId])
  @@index([isActive])
}

model Sale {
  id              String   @id @default(uuid())
  itemId          String
  userId          String
  quantity        Int
  unitPrice       Float
  totalAmount     Float
  paymentType     String
  referenceNumber String?  @default("")
  notes           String?  @default("")
  createdAt       DateTime @default(now())
  item            Item     @relation(fields: [itemId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
  @@index([paymentType])
}

model Gift {
  id            String   @id @default(uuid())
  itemId        String
  userId        String
  quantity      Int
  recipientName String?  @default("")
  reason        String?  @default("")
  createdAt     DateTime @default(now())
  item          Item     @relation(fields: [itemId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}

model Replacement {
  id            String   @id @default(uuid())
  itemId        String
  userId        String
  quantity      Int
  reason        String?  @default("")
  originalPurchaseDate DateTime?
  createdAt     DateTime @default(now())
  item          Item     @relation(fields: [itemId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float
  category    String   // e.g., 'rent', 'salary', 'electricity', 'tea', 'other'
  description String?  @default("")
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([createdAt])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // e.g., 'replacement'
  message   String
  isRead    Boolean  @default(false)
  userId    String   // who triggered the action (staff)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@index([userId])
}

model CashRegister {
  id                     String         @id @default(uuid())
  openingBalance         Float
  closingBalance         Float?
  expectedClosingBalance Float?
  openingNotes           String?        @default("") // JSON string of notes count
  closingNotes           String?        @default("") // JSON string of notes count
  openedAt               DateTime       @default(now())
  closedAt               DateTime?
  openedById             String
  closedById             String?
  status                 String         @default("OPEN") // OPEN, CLOSED
  discrepancyAmount      Float          @default(0)
  discrepancyReason      String?        @default("")
  notes                  String?        @default("")
  movements              CashMovement[]
  openedBy               User           @relation("OpenedBy", fields: [openedById], references: [id])
  closedBy               User?          @relation("ClosedBy", fields: [closedById], references: [id])

  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
}

model CashMovement {
  id          String       @id @default(uuid())
  registerId  String
  userId      String
  type        String       // ADDITION, REMOVAL
  amount      Float
  reason      String       // Bank Deposit, Owner Withdrawal, Change Float Adjustment, etc.
  notes       String?      @default("")
  createdAt   DateTime     @default(now())
  register    CashRegister @relation(fields: [registerId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@index([registerId])
  @@index([createdAt])
}
